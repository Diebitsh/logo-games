{
  "name": "logo-games",
  "version": "1.0.0",
  "description": "LogoGames — интерактивный сервис для логопедов и детей",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy": "ng deploy --base-href=/logo-games/",
    "cap:sync": "ng build --base-href ./ && cap sync",
    "cap:android": "npm run cap:sync && cap open android",
    "cap:ios": "npm run cap:sync && cap open ios",
    "optimize:assets": "node scripts/optimize-assets.mjs",
    "icons:render": "node scripts/render-icons.mjs",
    "icons:generate": "npm run icons:render && capacitor-assets generate"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@capacitor/android": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/filesystem": "^8.0.1",
    "@capacitor/ios": "^8.3.3",
    "@capacitor/preferences": "^8.0.1",
    "@flaticon/flaticon-uicons": "^3.1.0",
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/unbounded": "^5.2.8",
    "bootstrap": "^5.3.8",
    "idb": "^8.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.3",
    "@types/jasmine": "~5.1.0",
    "angular-cli-ghpages": "^3.0.3",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.0"
  }
}
